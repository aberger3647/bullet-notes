# Client (embedded at build time)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only: direct Postgres connection for schema migrations on deploy.
# Find this in Supabase → Project Settings → Database → Connection string (URI).
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase dashboard setup (not env vars):
# 1. Enable Google provider under Authentication → Providers
# 2. Add redirect URLs: http://localhost:5173/ and your production URL
# 3. Google Cloud OAuth redirect: https://<project-ref>.supabase.co/auth/v1/callback
